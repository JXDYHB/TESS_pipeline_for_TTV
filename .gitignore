# ---------------------------------------------------------------------------
# Output / run artefacts  (large, regenerable)
# ---------------------------------------------------------------------------
OUTPUT/
OUTPUT_*/
results/
*.pkl

# Slurm raw logs that land at the project root before being moved.
slurm_*.log
slurm_*.err

# ---------------------------------------------------------------------------
# Catalogue inputs  (excluded by default — user must provide their own)
# ---------------------------------------------------------------------------
data/*.csv

# ---------------------------------------------------------------------------
# Python virtualenv + cache
# ---------------------------------------------------------------------------
.venv/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
build/
dist/

# ---------------------------------------------------------------------------
# Editor / OS
# ---------------------------------------------------------------------------
.vscode/
.idea/
.DS_Store
*.swp

# ---------------------------------------------------------------------------
# Lightkurve / ArviZ / TLS caches (sometimes appear in cwd)
# ---------------------------------------------------------------------------
.lightkurve_cache/
.matplotlib/
.codex
